rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/nudges/{nudgeId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    match /classes/{classId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin()
        ||
        // existing member can update anything
        request.auth.uid in resource.data.members
        ||
        // non-member self-join: can only add their own uid to members
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
          request.resource.data.members.toSet().difference(resource.data.members.toSet())
            .hasOnly([request.auth.uid])
        )
      );
      allow delete: if request.auth != null
        && (request.auth.uid in resource.data.members || isAdmin());
    }

    match /userPublicStats/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
    }

    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
